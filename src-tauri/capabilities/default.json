{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://buymeacoffee.com/*" },
        { "url": "https://github.com/*" },
        { "url": "https://termpane.com/*" },
        { "url": "https://termpane.com" }
      ]
    }
  ]
}
